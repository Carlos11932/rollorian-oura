# Database (Neon Postgres)
# DATABASE_URL = pooled connection (used by the app at runtime)
# DIRECT_URL   = direct connection (used by Prisma CLI for migrations)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# Oura API OAuth2
OURA_CLIENT_ID=""
OURA_CLIENT_SECRET=""
OURA_REDIRECT_URI="http://localhost:3000/api/auth/oura/callback"

# Internal API Key (min 32 chars) — used by Donna to call /api/internal/*
INTERNAL_API_KEY=""

# Auth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
